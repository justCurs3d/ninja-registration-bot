{
  "name": "ninja-registration-bot",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "stop": "docker-compose down",
    "dev": "cross-env NODE_ENV=test nest start --debug --watch",
    "prod": "cross-env NODE_ENV=production docker-compose up -d --build",
    "restart:prod": "docker-compose down && cross-env NODE_ENV=production docker-compose up -d"
  },
  "dependencies": {
    "@nestjs/common": "11.1.19",
    "@nestjs/core": "11.1.19",
    "@nestjs/mongoose": "^11.0.4",
    "bcrypt": "^6.0.0",
    "cross-env": "10.1.0",
    "dotenv": "17.4.2",
    "mongoose": "^9.6.1",
    "nestjs-telegraf": "2.9.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "telegraf": "4.16.3",
    "telegraf-session-local": "2.1.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "typescript": "~5.9.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
